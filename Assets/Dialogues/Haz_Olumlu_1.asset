  - stat: 2
    min: 50
    max: 100
  answerA:
    answerText: "An\u0131 ya\u015Fa, yar\u0131n\u0131 d\xFC\u015F\xFCnme."
    effects:
    - stat: 2
      amount: 10
  answerB:
    answerText: "Ger\xE7ek haz, hak edilmi\u015F oland\u0131r."
